APP_NAME=CTI-Mobile API
APP_ENV=local
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://cti_mobile:cti_mobile_password@localhost:5432/cti_mobile
JWT_SECRET_KEY=change-this-local-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
FEED_SCHEDULER_ENABLED=true
FEED_SCHEDULER_INTERVAL_MINUTES=30
FEED_SCHEDULER_LIMIT_PER_SOURCE=3
FEED_SCHEDULER_CISA_KEV_LIMIT=10
